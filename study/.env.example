# =============================================================================
# GeniLocal — Variables d'environnement (EXEMPLE)
# =============================================================================
# Copiez ce fichier en .env et ajustez les valeurs selon votre environnement.
# Ce fichier PEUT être commité dans Git (il ne contient pas de secrets réels).
# =============================================================================

# --- Backend FastAPI ---
VITE_API_BASE_URL=http://localhost:8000/api
VITE_BACKEND_URL=http://localhost:8000

# --- Ollama (IA locale hors ligne) ---
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=mistral

# --- Paramètres IA ---
VITE_OLLAMA_TEMPERATURE=0.7
VITE_OLLAMA_NUM_PREDICT=500
VITE_OLLAMA_CONTEXT_LENGTH=2000
VITE_USE_OLLAMA=true

# --- Clés localStorage ---
VITE_STORAGE_KEY_HISTORY=study_ia_history
VITE_STORAGE_KEY_AVATAR=study_dicebear_config_detailed
VITE_STORAGE_KEY_IMPORTED_DOCS=genilocal_imported_documents_count
VITE_STORAGE_KEY_CHAT_COUNT=chat_message_count
